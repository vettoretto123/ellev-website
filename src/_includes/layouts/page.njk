---
layout: layouts/base.njk
---

<!-- HERO -->
<header class="hero">
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>

  <img src="/assets/images/logo.jpg" alt="VOICE Unlock Your Art" class="hero-logo" />

  <h1 class="hero-tagline">
    {{ t.hero_title_1 }} <span class="gold">{{ t.hero_title_gold }}</span><br/>
    <span class="teal">{{ t.hero_title_2 }}</span> {{ t.hero_title_3 }}
  </h1>
  <p class="hero-sub">{{ t.hero_sub }}</p>
  <a href="{{ t.cta_url }}" class="btn-main" style="margin-top:2.4rem">{{ t.cta_btn }}</a>

  <div class="hero-scroll">
    <div class="line"></div>
    <span>{{ t.scroll_label }}</span>
  </div>
</header>

<!-- PROBLEMA -->
<section id="problema" class="reveal two-col">
  <div class="problema-text">
    <p class="section-label">{{ t.problema_label }}</p>
    <h2 class="section-title">{{ t.problema_title_1 }}<br/><em>{{ t.problema_title_em }}</em></h2>
    <div class="divider"></div>
    <p>{{ t.problema_body_1 }}</p>
    <p><strong>{{ t.problema_body_2 }}</strong></p>
    <div class="pill-note">{{ t.problema_pill }}</div>
  </div>
  <ul class="blocchi-list">
    <li>
      <span class="icon">😰</span>
      <div><strong>{{ t.blocco_1_title }}</strong><span class="desc">{{ t.blocco_1_sub }}</span></div>
    </li>
    <li>
      <span class="icon">👁️</span>
      <div><strong>{{ t.blocco_2_title }}</strong><span class="desc">{{ t.blocco_2_sub }}</span></div>
    </li>
    <li>
      <span class="icon">🔁</span>
      <div><strong>{{ t.blocco_3_title }}</strong><span class="desc">{{ t.blocco_3_sub }}</span></div>
    </li>
    <li>
      <span class="icon">⚡</span>
      <div><strong>{{ t.blocco_4_title }}</strong><span class="desc">{{ t.blocco_4_sub }}</span></div>
    </li>
  </ul>
</section>

<!-- COS'È / WHAT IS -->
<section id="cose" class="reveal text-center">
  <p class="section-label">{{ t.cose_label }}</p>
  <h2 class="section-title">{{ t.cose_title_1 }}<br/><em>{{ t.cose_title_em }}</em></h2>
  <div class="divider mx-auto"></div>
  <p class="lead">{{ t.cose_body | safe }}</p>
  <div class="big-quote">{{ t.cose_quote }}</div>
</section>

<!-- METODO -->
<section id="metodo" class="reveal">
  <p class="section-label">{{ t.metodo_label }}</p>
  <h2 class="section-title">{{ t.metodo_title_1 }}<br/><em>{{ t.metodo_title_em }}</em></h2>
  <div class="divider"></div>
  <div class="pillars">
    <div class="pillar"><span class="num">01</span><h3>{{ t.pillar_1_title }}</h3><p>{{ t.pillar_1_body }}</p></div>
    <div class="pillar"><span class="num">02</span><h3>{{ t.pillar_2_title }}</h3><p>{{ t.pillar_2_body }}</p></div>
    <div class="pillar"><span class="num">03</span><h3>{{ t.pillar_3_title }}</h3><p>{{ t.pillar_3_body }}</p></div>
    <div class="pillar"><span class="num">04</span><h3>{{ t.pillar_4_title }}</h3><p>{{ t.pillar_4_body }}</p></div>
    <div class="pillar"><span class="num">05</span><h3>{{ t.pillar_5_title }}</h3><p>{{ t.pillar_5_body }}</p></div>
  </div>
</section>

<!-- PER CHI / WHO IT'S FOR -->
<section id="perchi" class="reveal two-col">
  <div>
    <p class="section-label">{{ t.perchi_label }}</p>
    <h2 class="section-title">{{ t.perchi_title_1 }}<br/><em>{{ t.perchi_title_em }}</em></h2>
    <div class="divider"></div>
    <div class="perchi-items">
      <div class="perchi-item">{{ t.perchi_1 }}</div>
      <div class="perchi-item">{{ t.perchi_2 }}</div>
      <div class="perchi-item">{{ t.perchi_3 }}</div>
      <div class="perchi-item">{{ t.perchi_4 }}</div>
      <div class="perchi-item">{{ t.perchi_5 }}</div>
    </div>
  </div>
  <div class="perchi-aside">
    <p class="aside-title">{{ t.perchi_aside_title }}</p>
    <ul>
      <li>{{ t.perchi_r1 }}</li>
      <li>{{ t.perchi_r2 }}</li>
      <li>{{ t.perchi_r3 }}</li>
      <li>{{ t.perchi_r4 }}</li>
      <li>{{ t.perchi_r5 }}</li>
      <li>{{ t.perchi_r6 }}</li>
    </ul>
  </div>
</section>

<!-- PER CHI NON È / NOT FOR YOU IF -->
<section id="nonperchi" class="reveal text-center">
  <p class="section-label">{{ t.nonperchi_label }}</p>
  <h2 class="section-title">{{ t.nonperchi_title_1 }}<br/><em>{{ t.nonperchi_title_em }}</em></h2>
  <div class="divider mx-auto"></div>
  <ul class="nonperchi-list">
    {% for item in t.nonperchi_items %}
    <li class="nonperchi-item">{{ item }}</li>
    {% endfor %}
  </ul>
</section>

<!-- STRUTTURA / STRUCTURE -->
<section id="struttura" class="reveal text-center">
  <p class="section-label">{{ t.struttura_label }}</p>
  <h2 class="section-title">{{ t.struttura_title_1 }}<br/><em>{{ t.struttura_title_em }}</em></h2>
  <div class="divider mx-auto"></div>
  <div class="struttura-grid">
    <div class="st-card">
      <div class="icon-big">🗓️</div>
      <span class="highlight">{{ t.st1_val }}</span>
      <h3>{{ t.st1_title }}</h3>
      <p>{{ t.st1_body }}</p>
    </div>
    <div class="st-card">
      <div class="icon-big">🎯</div>
      <span class="highlight">{{ t.st2_val }}</span>
      <h3>{{ t.st2_title }}</h3>
      <p>{{ t.st2_body }}</p>
    </div>
    <div class="st-card">
      <div class="icon-big">🛠️</div>
      <span class="highlight">{{ t.st3_val }}</span>
      <h3>{{ t.st3_title }}</h3>
      <p>{{ t.st3_body }}</p>
    </div>
  </div>
</section>

<!-- PERCHÉ / WHY -->
<section id="perche" class="reveal text-center">
  <p class="section-label">{{ t.perche_label }}</p>
  <h2 class="section-title">{{ t.perche_title_1 }}<br/><em>{{ t.perche_title_em }}</em></h2>
  <div class="divider mx-auto"></div>
  <p class="manifesto">{{ t.perche_manifesto | safe }}</p>
</section>

<!-- COACH / BIO -->
<section id="coach" class="reveal two-col">
  <div>
    <p class="section-label">{{ t.coach_label }}</p>
    <h2 class="section-title">{{ t.coach_title_1 }}<br/><em>{{ t.coach_title_em }}</em></h2>
    <div class="divider"></div>
    <p>{{ t.coach_bio_1 }}</p>
    <p>{{ t.coach_bio_2 }}</p>
  </div>
  <div class="coach-aside">
    <div class="coach-quote">{{ t.coach_quote }}</div>
    <p class="coach-name">— {{ t.coach_name }}</p>
  </div>
</section>

<!-- TESTIMONIANZE / TESTIMONIALS -->
{% if t.testi_show %}
<section id="testimonianze" class="reveal text-center">
  <p class="section-label">{{ t.testi_label }}</p>
  <h2 class="section-title">{{ t.testi_title_1 }}<br/><em>{{ t.testi_title_em }}</em></h2>
  <div class="divider mx-auto"></div>
  <div class="testi-carousel">
    <div class="testi-track">
      {% for testi in t.testi %}
      <div class="testi-card">
        <p class="testi-testo">{{ testi.testo }}</p>
        <p class="testi-nome">{{ testi.nome }}</p>
        <p class="testi-ruolo">{{ testi.ruolo }}</p>
      </div>
      {% endfor %}
    </div>
    <div class="testi-controls">
      <button class="testi-prev" aria-label="Precedente">&#8592;</button>
      <div class="testi-dots">
        {% for testi in t.testi %}
        <span class="testi-dot{% if loop.first %} active{% endif %}"></span>
        {% endfor %}
      </div>
      <button class="testi-next" aria-label="Successiva">&#8594;</button>
    </div>
  </div>
</section>
{% endif %}

<!-- FAQ -->
{% if t.faq_show %}
<section id="faq" class="reveal">
  <p class="section-label">{{ t.faq_label }}</p>
  <h2 class="section-title">{{ t.faq_title_1 }}<br/><em>{{ t.faq_title_em }}</em></h2>
  <div class="divider"></div>
  <div class="faq-list">
    {% for item in t.faq %}
    <details class="faq-item">
      <summary class="faq-question">{{ item.q }}</summary>
      <p class="faq-answer">{{ item.a }}</p>
    </details>
    {% endfor %}
  </div>
</section>
{% endif %}

<!-- CTA -->
<section id="cta" class="cta-section">
  <div class="cta-bg"></div>
  <div class="inner reveal">
    <span class="cta-eyebrow">{{ t.cta_eyebrow }}</span>
    <h2 class="cta-title">{{ t.cta_title_1 }}<br/><span>{{ t.cta_title_gold }}</span></h2>
    <p class="cta-body">{{ t.cta_body | safe }}</p>
    <a href="{{ t.cta_url }}" class="btn-main">{{ t.cta_btn }}</a>
    <p class="cta-note">{{ t.cta_note }}</p>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <img src="/assets/images/logo.jpg" alt="VOICE" />
  <div class="footer-social">
    {% for s in t.social %}
    {% if s.attivo %}
    <a href="{{ s.url }}" class="social-link" aria-label="{{ s.label }}" target="_blank" rel="noopener noreferrer">
      {% if s.icona == "instagram" %}
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
      {% elif s.icona == "facebook" %}
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
      {% elif s.icona == "tiktok" %}
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
      {% elif s.icona == "youtube" %}
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
      {% elif s.icona == "spotify" %}
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 11.973c2.5-1.473 5.5-.973 7.5.527M9 15c1.833-1 4.167-.667 6 .5M7.5 8.5c2.833-1.5 7-1 10 1.5"/></svg>
      {% endif %}
    </a>
    {% endif %}
    {% endfor %}
  </div>
  <p>{{ t.footer_copy }}</p>
</footer>
